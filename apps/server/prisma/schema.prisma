generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique
  passwordHash String?    @map("password_hash")
  googleId     String?    @unique @map("google_id")
  displayName  String     @map("display_name")
  avatarUrl    String?    @map("avatar_url")
  bio          String?    @map("bio")
  phoneNumber  String?    @map("phone_number")
  location     String?    @map("location")
  isOnline     Boolean    @default(false) @map("is_online")
  lastSeenAt   DateTime   @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at")
  rooms        Room[]     @relation("HostRooms")
  groupsCreated Group[]   @relation("GroupCreator")
  groupMemberships GroupMember[]
  participants Participant[]
  messages     Message[]
  meetingMinutesCreated MeetingMinute[]
  assistantThreads AssistantThread[]

  @@map("users")
}

model PendingRegistration {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  displayName  String   @map("display_name")
  passwordHash String   @map("password_hash")
  otpHash      String   @map("otp_hash")
  otpExpiresAt DateTime @map("otp_expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("pending_registrations")
}

model PendingPasswordReset {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  otpHash      String   @map("otp_hash")
  otpExpiresAt DateTime @map("otp_expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("pending_password_resets")
}

model Group {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  avatarUrl   String?  @map("avatar_url") @db.VarChar
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  isActive    Boolean  @default(true) @map("is_active")
  summarizerEnabled Boolean @default(false) @map("summarizer_enabled")

  creator User? @relation("GroupCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  members GroupMember[]
  rooms   Room[]
  meetingMinutes MeetingMinute[]
  minuteChunks MeetingMinuteChunk[]

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId  String   @map("group_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     String   @default("member") @db.VarChar(20)
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Room {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hostId    String?       @map("host_id") @db.Uuid
  groupId   String?       @map("group_id") @db.Uuid
  roomCode  String        @map("room_code") @unique
  name      String?
  isActive  Boolean       @default(true) @map("is_active")
  summarizerEnabled Boolean @default(false) @map("summarizer_enabled")
  createdAt DateTime      @default(now()) @map("created_at")
  endedAt   DateTime?     @map("ended_at")
  host      User?         @relation("HostRooms", fields: [hostId], references: [id])
  group     Group?        @relation(fields: [groupId], references: [id], onDelete: SetNull)
  participants Participant[]
  messages   Message[]
  meetingMinutes MeetingMinute?

  @@map("rooms")
}

model Participant {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId     String   @map("room_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  joinedAt   DateTime @default(now()) @map("joined_at")
  leftAt     DateTime? @map("left_at")
  isMuted    Boolean  @default(false) @map("is_muted")
  isCameraOff Boolean @default(false) @map("is_camera_off")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@map("participants")
}

model Message {
  id      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId  String   @map("room_id") @db.Uuid
  userId  String?  @map("user_id") @db.Uuid
  content String
  sentAt  DateTime @default(now()) @map("sent_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@map("messages")
}

model MeetingMinute {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId           String   @unique @map("room_id") @db.Uuid
  groupId          String?  @map("group_id") @db.Uuid
  createdBy        String?  @map("created_by") @db.Uuid
  title            String   @db.VarChar(200)
  rawTranscript    String   @map("raw_transcript")
  summaryMarkdown  String   @map("summary_markdown")
  durationSeconds  Int      @map("duration_seconds")
  participantCount Int      @map("participant_count")
  actionItems      Json     @default("[]") @map("action_items")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  room           Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  group          Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdByUser  User?  @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  chunks         MeetingMinuteChunk[]

  @@map("meeting_minutes")
}

// RAG chunks for "Ask AI across all meetings". The `embedding` column is a
// pgvector type Prisma doesn't model natively — it's declared Unsupported so
// the schema stays in sync (a future `migrate dev` won't drop the table), and
// every read/write goes through raw SQL (`$queryRaw`), the pattern used across
// this codebase. group_id is denormalized from the parent minutes so the
// retrieval permission filter is a single indexed column.
model MeetingMinuteChunk {
  id         String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  minutesId  String                     @map("minutes_id") @db.Uuid
  groupId    String?                    @map("group_id") @db.Uuid
  chunkIndex Int                        @map("chunk_index")
  chunkText  String                     @map("chunk_text")
  embedding  Unsupported("vector(384)")
  createdAt  DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)

  minutes MeetingMinute @relation(fields: [minutesId], references: [id], onDelete: Cascade)
  group   Group?        @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([minutesId, chunkIndex])
  @@index([groupId])
  @@map("meeting_minute_chunks")
}

// Persistent chat threads for the personal AI assistant (ChatGPT-style history).
model AssistantThread {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AssistantMessage[]

  @@index([userId, updatedAt])
  @@map("assistant_threads")
}

model AssistantMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  threadId  String   @map("thread_id") @db.Uuid
  role      String   @db.VarChar(12)
  content   String
  sources   Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  thread AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@map("assistant_messages")
}
